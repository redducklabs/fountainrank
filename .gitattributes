* text=auto eol=lf

# Explicitly binary — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pmtiles binary

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
